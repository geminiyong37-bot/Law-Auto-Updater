function syncLawsFromGithub() {
  const GITHUB_USER = "geminiyong37-bot";
  const REPO_NAME = "law-auto-updater";
  const ROOT_FOLDER_ID = "16zT278nodzMpY-XIM3cn-fBAIrfR8I3Q"; // Laws-Folder ID
  
  // 1. 파이썬 코드의 LAWS_TO_FETCH 및 ADMIN_RULES_TO_FETCH를 통합하여 정의
  // 파일명 규칙: 파이썬에서 replace("·", "_").replace(" ", "_") 처리된 형식을 반영
  const folderMap = {
    "사립대학": [
      "사립학교법.md", "사립학교법_시행령.md", "사학기관_재무_회계_규칙.md", 
      "사학기관_재무_회계_규칙에_대한_특례규칙.md", "대학설립_운영_규정.md", 
      "대학설립_운영_규정_시행규칙.md", "사이버대학_설립_운영_규정.md", "대학_등록금에_관한_규칙.md",
      "사학기관_외부회계감사_유의사항.md", "사학기관_외부회계감사_감리에_관한_고시.md", 
      "사학기관_외부감사인_지정_등에_관한_고시.md"
    ],
    "평생교육": ["평생교육법.md", "평생교육법_시행령.md", "평생교육법_시행규칙.md"],
    "부속병원": ["의료기관_회계기준_규칙.md", "재무제표_세부_작성방법.md"],
    "산학협력단": [
      "산업교육진흥_및_산학연협력촉진에_관한_법률.md", "산업교육진흥_및_산학연협력촉진에_관한_법률_시행령.md", 
      "산업교육진흥_및_산학연협력촉진에_관한_법률_시행규칙.md", "국가연구개발혁신법.md", 
      "국가연구개발혁신법_시행령.md", "국가연구개발혁신법_시행규칙.md",
      "산학협력단회계처리규칙.md", "국가연구개발사업_연구개발비_사용_기준.md", 
      "산학연협력기술지주회사_설립절차_등에_관한_규정.md", "계약학과_설치_운영_규정.md", 
      "국가연구개발_시설_장비의_관리_등에_관한_표준지침.md"
    ],
    "재외교육기관": [
      "재외국민의_교육지원_등에_관한_법률.md", "재외국민의_교육지원_등에_관한_법률_시행령.md", 
      "재외국민의_교육지원_등에_관한_법률_시행규칙.md", "재외공관_비소모품_관리규정.md"
    ],
    "학교기업": ["학교기업_회계처리규칙.md"],
    "기본재산": ["교육용_기본재산_처분에_대한_기준_고시.md"]
  };
  
  const rootFolder = DriveApp.getFolderById(ROOT_FOLDER_ID);
  
  for (let folderName in folderMap) {
    // 2. 드라이브 내 하위 폴더 확인 및 생성
    let targetFolder;
    const subFolders = rootFolder.getFoldersByName(folderName);
    
    if (subFolders.hasNext()) {
      targetFolder = subFolders.next();
    } else {
      targetFolder = rootFolder.createFolder(folderName);
      console.log(`🆕 새 폴더 생성됨: ${folderName}`);
    }
    
    // 3. 해당 폴더 안에 파일 동기화
    folderMap[folderName].forEach(fileName => {
      // 깃허브 raw 경로 (파이썬 스크립트가 업로드하는 경로와 일치해야 함)
      const url = `https://raw.githubusercontent.com/${GITHUB_USER}/${REPO_NAME}/main/laws/${folderName}/${fileName}`;
      const txtFileName = fileName.replace('.md', '.txt');
      
      try {
        const response = UrlFetchApp.fetch(url);
        const content = response.getContentText();
        
        // --- [1] .md 파일 업데이트 ---
        const existingMdFiles = targetFolder.getFilesByName(fileName);
        if (existingMdFiles.hasNext()) {
          existingMdFiles.next().setContent(content);
          console.log(`✅ [MD] 업데이트: ${folderName}/${fileName}`);
        } else {
          targetFolder.createFile(fileName, content);
          console.log(`🆕 [MD] 신규 생성: ${folderName}/${fileName}`);
        }

        // --- [2] .txt 파일 업데이트 (노트북LM 인식용) ---
        const existingTxtFiles = targetFolder.getFilesByName(txtFileName);
        if (existingTxtFiles.hasNext()) {
          existingTxtFiles.next().setContent(content);
          console.log(`✅ [TXT] 업데이트: ${folderName}/${txtFileName}`);
        } else {
          targetFolder.createFile(txtFileName, content);
          console.log(`🆕 [TXT] 신규 생성: ${folderName}/${txtFileName}`);
        }
        
      } catch (e) {
        console.log(`❌ 실패: ${folderName}/${fileName} (GitHub에 파일이 있는지 확인 필요) - ${e.message}`);
      }
    });
  }
}
