### --- [보안 및 설정] ---
# API 키, DB 접속 정보 등 민감 정보가 담긴 파일
.env
.env.local
.env.*
secrets.json
config.py
auth.yaml
*.pem
*.key

### --- [Python 시스템 파일] ---
# 컴파일된 파이썬 파일 및 캐시
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

### --- [가상환경 (Virtual Environments)] ---
# 프로젝트마다 생성하는 독립된 환경 폴더
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

### --- [IDE 및 에디터 설정] ---
# PyCharm, VS Code 등의 개별 설정
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject
.settings/

### --- [운영체제 임시 파일] ---
# macOS 및 Windows에서 자동 생성되는 파일
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

### --- [데이터 및 로그] ---
# 수집된 데이터나 실행 로그 (필요 시 주석 해제)
*.log
# data/
# laws/